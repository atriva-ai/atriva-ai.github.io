---
// @ts-ignore
import ReuseIcon from "@/assets/icons/bring-to-front.svg";
import AgentIcon from "@/assets/icons/bot.svg";
import EventIcon from "@/assets/icons/message-square.svg";
import OpenIcon from "@/assets/icons/github.svg";
import DevelopIcon from "@/assets/icons/git-pull-request-arrow.svg";
import HardwareIcon from "@/assets/icons/microchip.svg";

const features = [
  {
    title: "Reusable Architecture",
    description:
      "Build once, deploy anywhere — our modular setup ensures long-term reusability across multiple edge AI projects.",
    icon: ReuseIcon,
  },
  {
    title: "Event-Driven LLM Integration",
    description:
      "Atriva emits structured events that LLMs and VLMs can act on — enabling intelligent alerts, natural language summaries, and autonomous decision-making.",
    icon: EventIcon,
  },
  {
    title: "Agentic-Ready Architecture",
    description:
      "Designed as a perception layer for AI agents. Connect to any LLM or orchestration framework — LangGraph, CrewAI, or your own — without custom glue code.",
    icon: AgentIcon,
  },
  {
    title: "Open Source First",
    description:
      "Most of Atriva’s source code is open source — giving developers transparency, flexibility, and the freedom to customize without vendor lock-in.",
    icon: OpenIcon,
  },
  {
    title: "Developer Friendly",
    description:
      "Simple APIs, clear docs, and prebuilt SDKs make it easy to go from prototype to production.",
    icon: DevelopIcon,
  },
  {
    title: "Hardware Agnostic",
    description:
      "Run on any AI accelerator — GPUs, NPUs, SoCs — without being locked into a single vendor.",
    icon: HardwareIcon,
  },
];
---

<section class="relative py-20 md:py-8">
    <div class="container max-w-screen-xl mx-auto px-4">

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Why Developers Choose Atriva
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    Open source, hardware-agnostic, and built for production — the platform serious edge AI developers reach for.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        {/* Icon container */}
        <div class="flex-shrink-0">
          <item.icon class="w-10 h-10 text-[#48A18D]" />
        </div>

        {/* Text container */}
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>
</div>
</section>
